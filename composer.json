{
    "name": "papi-ai/laravel",
    "description": "Laravel bridge for PapiAI - AI agent library",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Marcello Duarte",
            "email": "marcello.duarte@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "papi-ai/papi-core": "^0.9",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "mockery/mockery": "^1.6",
        "friendsofphp/php-cs-fixer": "^3.0",
        "vimeo/psalm": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "PapiAI\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PapiAI\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PapiAI\\Laravel\\PapiServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest",
        "test:coverage": "XDEBUG_MODE=coverage pest --coverage --min=60",
        "lint": "php-cs-fixer fix --dry-run --diff",
        "lint:fix": "php-cs-fixer fix",
        "analyse": "psalm",
        "ci": ["@lint", "@analyse", "@test:coverage"]
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable"
}
